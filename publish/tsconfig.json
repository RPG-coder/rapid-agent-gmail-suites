{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "noLib": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "noImplicitAny": false,
    "strict": false,
    "noEmit": false,
    "types": ["google-apps-script"]
  },
  "include": ["sidebar-ui/**/*.ts"]
}
